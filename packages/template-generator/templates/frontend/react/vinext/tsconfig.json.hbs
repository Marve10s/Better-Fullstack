{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"]
    }{{#if (or (eq serverDeploy "cloudflare") (eq webDeploy "cloudflare"))}},
    "types": [
      "@cloudflare/workers-types"
    ]{{/if}}
  },
  "include": [
    {{#if (or (eq serverDeploy "cloudflare") (eq webDeploy "cloudflare"))}}
    "../server/env.d.ts",
    {{/if}}
    "./**/*.ts",
    "./**/*.tsx",
    "./**/*.mts"
  ],
  "exclude": [
    "./node_modules",
    "./dist"
  ]
}
