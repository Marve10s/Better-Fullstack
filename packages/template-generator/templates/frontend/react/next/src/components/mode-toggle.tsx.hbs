"use client"

{{#if (eq shadcnIconLibrary "tabler")}}
import { IconMoon as Moon, IconSun as Sun } from "@tabler/icons-react"
{{else if (eq shadcnIconLibrary "hugeicons")}}
import { HugeiconsIcon, type HugeiconsIconProps } from "@hugeicons/react"
import { Moon02Icon, Sun03Icon } from "@hugeicons/core-free-icons"
{{else if (eq shadcnIconLibrary "phosphor")}}
import { Moon, Sun } from "@phosphor-icons/react"
{{else if (eq shadcnIconLibrary "remixicon")}}
import { RiMoonLine as Moon, RiSunLine as Sun } from "@remixicon/react"
{{else if (eq shadcnIconLibrary "heroicons")}}
import { MoonIcon as Moon, SunIcon as Sun } from "@heroicons/react/24/outline"
{{else if (eq shadcnIconLibrary "react-icons")}}
import { FaMoon as Moon, FaSun as Sun } from "react-icons/fa"
{{else}}
import { Moon, Sun } from "lucide-react"
{{/if}}
import { useTheme } from "next-themes"
import { Button } from "@/components/ui/button"
import {
  DropdownMenu,
  DropdownMenuContent,
  DropdownMenuItem,
  DropdownMenuTrigger,
} from "@/components/ui/dropdown-menu"

{{#if (eq shadcnIconLibrary "hugeicons")}}
const Moon = (props: Omit<HugeiconsIconProps, "icon">) => (
  <HugeiconsIcon icon={Moon02Icon} {...props} />
)
const Sun = (props: Omit<HugeiconsIconProps, "icon">) => (
  <HugeiconsIcon icon={Sun03Icon} {...props} />
)

{{/if}}
export function ModeToggle() {
  const { setTheme } = useTheme()

  return (
    <DropdownMenu>
      <DropdownMenuTrigger render={<Button variant="outline" size="icon" />}>
        <Sun className="h-[1.2rem] w-[1.2rem] rotate-0 scale-100 transition-all dark:-rotate-90 dark:scale-0" />
        <Moon className="absolute h-[1.2rem] w-[1.2rem] rotate-90 scale-0 transition-all dark:rotate-0 dark:scale-100" />
        <span className="sr-only">Toggle theme</span>
      </DropdownMenuTrigger>
      <DropdownMenuContent align="end">
        <DropdownMenuItem onClick={() => setTheme("light")}>
          Light
        </DropdownMenuItem>
        <DropdownMenuItem onClick={() => setTheme("dark")}>
          Dark
        </DropdownMenuItem>
        <DropdownMenuItem onClick={() => setTheme("system")}>
          System
        </DropdownMenuItem>
      </DropdownMenuContent>
    </DropdownMenu>
  )
}
