{{#if (eq shadcnIconLibrary "tabler")}}
import { IconLoader2 as Loader2 } from "@tabler/icons-react";
{{else if (eq shadcnIconLibrary "hugeicons")}}
import { HugeiconsIcon, type HugeiconsIconProps } from "@hugeicons/react";
import { Loading03Icon } from "@hugeicons/core-free-icons";
{{else if (eq shadcnIconLibrary "phosphor")}}
import { SpinnerGap as Loader2 } from "@phosphor-icons/react";
{{else if (eq shadcnIconLibrary "remixicon")}}
import { RiLoader4Line as Loader2 } from "@remixicon/react";
{{else if (eq shadcnIconLibrary "heroicons")}}
import { ArrowPathIcon as Loader2 } from "@heroicons/react/24/outline";
{{else if (eq shadcnIconLibrary "react-icons")}}
import { FaSpinner as Loader2 } from "react-icons/fa";
{{else}}
import { Loader2 } from "lucide-react";
{{/if}}

{{#if (eq shadcnIconLibrary "hugeicons")}}
const Loader2 = (props: Omit<HugeiconsIconProps, "icon">) => (
  <HugeiconsIcon icon={Loading03Icon} {...props} />
);

{{/if}}
export default function Loader() {
  return (
    <div className="flex h-full items-center justify-center pt-8">
      <Loader2 className="animate-spin" />
    </div>
  );
}
