# Environment Configuration
# Copy this file to .env and update the values

# Application
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database (if using SQLAlchemy/SQLModel)
{{#if (eq database "postgres")}}
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/{{projectName}}
{{else}}
DATABASE_URL=sqlite:///./app.db
{{/if}}

# OpenAI (if using AI frameworks)
OPENAI_API_KEY=your-openai-api-key

# Anthropic (if using Anthropic SDK)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Celery (if using task queue)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
{{#if (eq pythonCaching "redis")}}

# redis-py caching
REDIS_URL=redis://127.0.0.1:6379/0
{{/if}}
{{#if (eq pythonObservability "opentelemetry")}}

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
{{/if}}
{{#if (eq pythonAuth "fastapi-users")}}

# FastAPI Users
AUTH_SECRET=change-me-to-a-real-secret
USERS_DATABASE_URL=sqlite+aiosqlite:///./users.db
{{/if}}
{{#if (eq pythonRealtime "websockets")}}

# websockets server
WS_HOST=0.0.0.0
WS_PORT=8765
{{/if}}
