{{#if (eq pythonRealtime "websockets")}}
"""WebSocket broadcast server built on the websockets library.

Run standalone with:

    uv run python -m app.realtime
"""

import asyncio
import os

import websockets
from websockets.asyncio.server import ServerConnection, serve

CONNECTIONS: set[ServerConnection] = set()


async def handler(connection: ServerConnection) -> None:
    """Track the connection and echo inbound messages to all clients."""
    CONNECTIONS.add(connection)
    try:
        async for message in connection:
            websockets.broadcast(CONNECTIONS, message)
    finally:
        CONNECTIONS.discard(connection)


async def main() -> None:
    """Serve WebSocket connections until cancelled."""
    host = os.getenv("WS_HOST", "0.0.0.0")
    port = int(os.getenv("WS_PORT", "8765"))
    async with serve(handler, host, port):
        await asyncio.get_running_loop().create_future()


if __name__ == "__main__":
    asyncio.run(main())
{{/if}}
