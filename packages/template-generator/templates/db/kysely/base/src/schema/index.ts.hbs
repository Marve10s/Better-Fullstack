import type { {{#unless (isBetterAuth auth)}}Generated, {{/unless}}ColumnType } from "kysely";

{{#if (isBetterAuth auth)}}
export interface UserTable {
	id: string;
	name: string;
	email: string;
	emailVerified: number;
	image: string | null;
	createdAt: ColumnType<Date, string | undefined, never>;
	updatedAt: ColumnType<Date, string | undefined, never>;
}

export interface SessionTable {
	id: string;
	expiresAt: ColumnType<Date, string, string>;
	token: string;
	createdAt: ColumnType<Date, string | undefined, never>;
	updatedAt: ColumnType<Date, string | undefined, never>;
	ipAddress: string | null;
	userAgent: string | null;
	userId: string;
}

export interface AccountTable {
	id: string;
	accountId: string;
	providerId: string;
	userId: string;
	accessToken: string | null;
	refreshToken: string | null;
	idToken: string | null;
	accessTokenExpiresAt: ColumnType<Date, string | null, string | null>;
	refreshTokenExpiresAt: ColumnType<Date, string | null, string | null>;
	scope: string | null;
	password: string | null;
	createdAt: ColumnType<Date, string | undefined, never>;
	updatedAt: ColumnType<Date, string | undefined, never>;
}

export interface VerificationTable {
	id: string;
	identifier: string;
	value: string;
	expiresAt: ColumnType<Date, string, string>;
	createdAt: ColumnType<Date, string | undefined, never>;
	updatedAt: ColumnType<Date, string | undefined, never>;
}

{{else}}
export interface ExampleTable {
	id: Generated<number>;
	name: string;
	createdAt: ColumnType<Date, string | undefined, never>;
}

{{/if}}
export interface Database {
{{#if (isBetterAuth auth)}}
	user: UserTable;
	session: SessionTable;
	account: AccountTable;
	verification: VerificationTable;
{{else}}
	example: ExampleTable;
{{/if}}
}
