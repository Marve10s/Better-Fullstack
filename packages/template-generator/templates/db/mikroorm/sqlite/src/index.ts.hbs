import { MikroORM, defineConfig } from "@mikro-orm/sqlite";
import { env } from "@{{projectName}}/env/server";

const config = defineConfig({
	dbName: env.DATABASE_URL.replace("file:", ""),
	entities: ["./src/entities"],
	entitiesTs: ["./src/entities"],
	debug: process.env.NODE_ENV !== "production",
});

let orm: Awaited<ReturnType<typeof MikroORM.init>> | null = null;

export const initializeDatabase = async () => {
	orm ??= await MikroORM.init(config);
	return orm;
};

export const getEntityManager = async () => {
	const db = await initializeDatabase();
	return db.em.fork();
};

export const db = {
	getORM: initializeDatabase,
	getEM: getEntityManager,
};
