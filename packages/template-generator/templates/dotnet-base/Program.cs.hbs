{{#if dotnetHasEfCore}}
using Microsoft.EntityFrameworkCore;
{{/if}}
{{#if dotnetHasMvc}}
using Microsoft.AspNetCore.Mvc;
{{/if}}
{{#if dotnetHasBlazor}}
using {{dotnetNamespace}}.Components;
{{/if}}
{{#if dotnetHasDapper}}
using Dapper;
{{#if (eq database "postgres")}}
using Npgsql;
{{else}}
using Microsoft.Data.Sqlite;
{{/if}}
{{/if}}
{{#if dotnetHasLinq2Db}}
using LinqToDB;
using LinqToDB.Data;
using LinqToDB.Mapping;
{{/if}}
{{#if dotnetHasIdentity}}
using Microsoft.AspNetCore.Identity;
{{/if}}
{{#if dotnetHasAuth0AspNet}}
using Auth0.AspNetCore.Authentication;
{{/if}}
{{#if dotnetHasDuendeIdentityServer}}
using Duende.IdentityServer;
using Duende.IdentityServer.Models;
{{/if}}
{{#if dotnetHasSignalR}}
using Microsoft.AspNetCore.SignalR;
{{/if}}
{{#if dotnetHasSerilog}}
using Serilog;
{{/if}}
{{#if dotnetHasNLog}}
using NLog.Web;
{{/if}}
{{#if dotnetHasOpenTelemetry}}
using OpenTelemetry.Metrics;
using OpenTelemetry.Trace;
{{/if}}
{{#if dotnetHasHangfire}}
using Hangfire;
using Hangfire.InMemory;
{{/if}}
{{#if dotnetHasQuartz}}
using Quartz;
{{/if}}

var builder = WebApplication.CreateBuilder(args);

{{#if dotnetHasMvc}}
builder.Services.AddControllers();
{{/if}}
{{#if dotnetHasBlazor}}
builder.Services.AddRazorComponents()
    .AddInteractiveServerComponents();
{{/if}}
{{#if dotnetHasSerilog}}
builder.Host.UseSerilog((context, configuration) =>
    configuration.ReadFrom.Configuration(context.Configuration).WriteTo.Console());
{{/if}}
{{#if dotnetHasNLog}}
builder.Logging.ClearProviders();
builder.Host.UseNLog();
{{/if}}

{{#if dotnetHasEfCore}}
builder.Services.AddDbContext<AppDbContext>(options =>
{
{{#if (eq database "postgres")}}
    var connectionString = builder.Configuration.GetConnectionString("DefaultConnection")
        ?? "Host=localhost;Port=5432;Database={{projectName}};Username=postgres;Password=postgres";
    options.UseNpgsql(connectionString);
{{else}}
    var connectionString = builder.Configuration.GetConnectionString("DefaultConnection")
        ?? "Data Source={{dotnetProjectName}}.db";
    options.UseSqlite(connectionString);
{{/if}}
});
{{/if}}
{{#if (and dotnetHasMinimalApiTodos dotnetHasDapperTodos)}}
var dapperConnectionString = builder.Configuration.GetConnectionString("DefaultConnection")
{{#if (eq database "postgres")}}
    ?? "Host=localhost;Port=5432;Database={{projectName}};Username=postgres;Password=postgres";
{{else}}
    ?? "Data Source={{dotnetProjectName}}.db";
{{/if}}
{{/if}}
{{#if (and dotnetHasMinimalApiTodos dotnetHasLinq2DbTodos)}}
var linq2DbConnectionString = builder.Configuration.GetConnectionString("DefaultConnection")
{{#if (eq database "postgres")}}
    ?? "Host=localhost;Port=5432;Database={{projectName}};Username=postgres;Password=postgres";
{{else}}
    ?? "Data Source={{dotnetProjectName}}.db";
{{/if}}
{{/if}}
{{#if dotnetHasIdentity}}
builder.Services.AddAuthentication();
builder.Services.AddAuthorization();
{{#if dotnetHasEfCore}}
builder.Services.AddIdentityCore<IdentityUser>()
    .AddEntityFrameworkStores<AppDbContext>();
{{/if}}
{{/if}}
{{#if dotnetHasAuth0AspNet}}
builder.Services.AddAuth0WebAppAuthentication(options =>
{
    options.Domain = builder.Configuration["Auth0:Domain"] ?? "your-tenant.us.auth0.com";
    options.ClientId = builder.Configuration["Auth0:ClientId"] ?? "AUTH0_CLIENT_ID";
    options.ClientSecret = builder.Configuration["Auth0:ClientSecret"];
});
builder.Services.AddAuthorization();
{{/if}}
{{#if dotnetHasDuendeIdentityServer}}
builder.Services
    .AddIdentityServer()
    .AddInMemoryApiScopes(new[]
    {
        new ApiScope("api", "{{projectName}} API"),
    })
    .AddInMemoryClients(new[]
    {
        new Client
        {
            ClientId = "{{dotnetCloudName}}-machine",
            ClientSecrets = { new Secret("development-secret".Sha256()) },
            AllowedGrantTypes = GrantTypes.ClientCredentials,
            AllowedScopes = { "api" },
        },
    })
    .AddDeveloperSigningCredential();
{{/if}}
{{#if dotnetHasSignalR}}
builder.Services.AddSignalR();
{{/if}}
{{#if (eq dotnetApi "graphql-hotchocolate")}}
builder.Services.AddGraphQLServer().AddQueryType<Query>();
{{/if}}
{{#if (eq dotnetApi "grpc-dotnet")}}
builder.Services.AddGrpc();
{{/if}}
{{#if dotnetHasHealthChecks}}
builder.Services.AddHealthChecks();
{{/if}}
{{#if dotnetHasMemoryCache}}
builder.Services.AddMemoryCache();
{{/if}}
{{#if dotnetHasRedis}}
builder.Services.AddStackExchangeRedisCache(options =>
{
    options.Configuration = builder.Configuration.GetConnectionString("Redis") ?? "localhost:6379";
});
{{/if}}
{{#if dotnetHasOpenTelemetry}}
builder.Services.AddOpenTelemetry()
    .WithMetrics(metrics => metrics.AddAspNetCoreInstrumentation())
    .WithTracing(tracing => tracing.AddAspNetCoreInstrumentation());
{{/if}}
{{#if dotnetHasHangfire}}
builder.Services.AddHangfire(configuration => configuration.UseInMemoryStorage());
builder.Services.AddHangfireServer();
{{/if}}
{{#if dotnetHasQuartz}}
builder.Services.AddQuartz();
builder.Services.AddQuartzHostedService(options => options.WaitForJobsToComplete = true);
{{/if}}
{{#if dotnetHasHostedServices}}
builder.Services.AddHostedService<Worker>();
{{/if}}
builder.Services.AddCors(options =>
{
    options.AddDefaultPolicy(policy =>
        policy.AllowAnyOrigin().AllowAnyHeader().AllowAnyMethod());
});

var app = builder.Build();

app.UseCors();

{{#if dotnetHasAuthentication}}
app.UseAuthentication();
app.UseAuthorization();

{{/if}}
{{#if dotnetHasDuendeIdentityServer}}
app.UseIdentityServer();

{{/if}}
{{#if dotnetHasBlazor}}
app.UseAntiforgery();

app.MapGet("/api/status", () => Results.Ok(new
{
    name = "{{projectName}}",
    framework = "{{dotnetWebFramework}}",
    status = "ok"
}));
{{else}}
app.MapGet("/", () => Results.Ok(new
{
    name = "{{projectName}}",
    framework = "{{dotnetWebFramework}}",
    status = "ok"
}));
{{/if}}

{{#if dotnetHasMinimalApiTodos}}
{{#if dotnetHasEfCore}}
app.MapGet("/api/todos", async (AppDbContext db) =>
{
    return Results.Ok(await db.Todos.OrderBy(todo => todo.Id).ToListAsync());
});
{{/if}}
{{#if dotnetHasDapperTodos}}
app.MapGet("/api/todos", async () =>
{
    await using var db = TodoDapper.CreateConnection(dapperConnectionString);
    await TodoDapper.EnsureSchemaAsync(db);
    var todos = await db.QueryAsync<TodoItem>("SELECT Id, Title, Complete FROM Todos ORDER BY Id");
    return Results.Ok(todos);
});
{{/if}}
{{#if dotnetHasLinq2DbTodos}}
app.MapGet("/api/todos", () =>
{
    using var db = TodoLinq2Db.CreateConnection(linq2DbConnectionString);
    TodoLinq2Db.EnsureSchema(db);
    var todos = db.Todos.OrderBy(todo => todo.Id).ToList();
    return Results.Ok(todos);
});
{{/if}}
{{#if (and (not dotnetHasEfCore) (not dotnetHasDapperTodos) (not dotnetHasLinq2DbTodos))}}
app.MapGet("/api/todos", () =>
{
    return Results.Ok(Array.Empty<TodoItem>());
});
{{/if}}

{{#if dotnetHasEfCore}}
app.MapPost("/api/todos", async (TodoInput input, AppDbContext db) =>
{
    var todo = new TodoItem { Title = input.Title, Complete = false };
    db.Todos.Add(todo);
    await db.SaveChangesAsync();
    return Results.Created($"/api/todos/{todo.Id}", todo);
});
{{/if}}
{{#if dotnetHasDapperTodos}}
app.MapPost("/api/todos", async (TodoInput input) =>
{
    await using var db = TodoDapper.CreateConnection(dapperConnectionString);
    await TodoDapper.EnsureSchemaAsync(db);
{{#if (eq database "postgres")}}
    const string sql = """
        INSERT INTO Todos (Title, Complete)
        VALUES (@Title, @Complete)
        RETURNING Id, Title, Complete
        """;
    var todo = await db.QuerySingleAsync<TodoItem>(sql, new { input.Title, Complete = false });
{{else}}
    const string sql = """
        INSERT INTO Todos (Title, Complete)
        VALUES (@Title, @Complete);
        SELECT Id, Title, Complete
        FROM Todos
        WHERE Id = last_insert_rowid()
        """;
    var todo = await db.QuerySingleAsync<TodoItem>(sql, new { input.Title, Complete = false });
{{/if}}
    return Results.Created($"/api/todos/{todo.Id}", todo);
});
{{/if}}
{{#if dotnetHasLinq2DbTodos}}
app.MapPost("/api/todos", (TodoInput input) =>
{
    using var db = TodoLinq2Db.CreateConnection(linq2DbConnectionString);
    TodoLinq2Db.EnsureSchema(db);
    var todo = new TodoItem { Title = input.Title, Complete = false };
    todo.Id = db.InsertWithInt32Identity(todo);
    return Results.Created($"/api/todos/{todo.Id}", todo);
});
{{/if}}
{{#if (and (not dotnetHasEfCore) (not dotnetHasDapperTodos) (not dotnetHasLinq2DbTodos))}}
app.MapPost("/api/todos", (TodoInput input) =>
{
    var todo = new TodoItem { Id = 1, Title = input.Title, Complete = false };
    return Results.Created($"/api/todos/{todo.Id}", todo);
});
{{/if}}
{{/if}}
{{#if dotnetHasMvc}}
app.MapControllers();
{{/if}}
{{#if (eq dotnetApi "graphql-hotchocolate")}}
app.MapGraphQL();
{{/if}}
{{#if dotnetHasSignalR}}
app.MapHub<UpdatesHub>("/hubs/updates");
{{/if}}
{{#if dotnetHasHealthChecks}}
app.MapHealthChecks("/health");
{{/if}}
{{#if dotnetHasHangfire}}
app.MapHangfireDashboard();
{{/if}}
{{#if dotnetHasBlazor}}
app.MapRazorComponents<App>()
    .AddInteractiveServerRenderMode();
{{/if}}

app.Run();

public partial class Program;

{{#if dotnetHasLinq2DbTodos}}
[Table("Todos")]
{{/if}}
public sealed class TodoItem
{
{{#if dotnetHasLinq2DbTodos}}
    [PrimaryKey, Identity]
{{/if}}
    public int Id { get; set; }
{{#if dotnetHasLinq2DbTodos}}
    [Column, NotNull]
