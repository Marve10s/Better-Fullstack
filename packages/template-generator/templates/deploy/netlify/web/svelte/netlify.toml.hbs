# Netlify configuration for {{projectName}} SvelteKit app
# https://docs.netlify.com/frameworks/sveltekit/
#
# In the Netlify dashboard, set the site's base directory to "apps/web".
# SvelteKit's adapter-auto picks the Netlify adapter during CI builds.

[build]
  command = "{{packageManager}} run build"
  publish = "build"
