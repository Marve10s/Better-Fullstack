<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
{{#if isJavaSpringBoot}}
	<parent>
		<groupId>org.springframework.boot</groupId>
		<artifactId>spring-boot-starter-parent</artifactId>
		<version>4.0.5</version>
		<relativePath/>
	</parent>
{{/if}}
	<groupId>{{javaGroupId}}</groupId>
	<artifactId>{{javaArtifactId}}</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<name>{{projectName}}</name>
	<description>Generated by Better Fullstack</description>
	<properties>
{{#if isJavaSpringBoot}}
		<java.version>21</java.version>
{{#if hasJavaSpringdocOpenapi}}
		<springdoc.version>3.0.3</springdoc.version>
{{/if}}
{{#if hasJavaLombok}}
		<lombok.version>1.18.38</lombok.version>
{{/if}}
{{#if hasJavaAssertj}}
		<assertj.version>3.27.7</assertj.version>
{{/if}}
{{#if hasJavaRestAssured}}
		<rest-assured.version>6.0.0</rest-assured.version>
{{/if}}
{{#if hasJavaWireMock}}
		<wiremock.version>3.13.2</wiremock.version>
{{/if}}
{{#if hasJavaAwaitility}}
		<awaitility.version>4.3.0</awaitility.version>
{{/if}}
{{else}}
		<maven.compiler.release>21</maven.compiler.release>
		<project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
{{#if hasJavaTests}}
		<junit.version>5.12.2</junit.version>
{{#if hasJavaAssertj}}
		<assertj.version>3.27.7</assertj.version>
{{/if}}
{{#if hasJavaMockito}}
		<mockito.version>5.15.2</mockito.version>
{{/if}}
{{#if hasJavaTestcontainers}}
		<testcontainers.version>1.20.4</testcontainers.version>
{{/if}}
{{#if hasJavaRestAssured}}
		<rest-assured.version>6.0.0</rest-assured.version>
{{/if}}
{{#if hasJavaWireMock}}
		<wiremock.version>3.13.2</wiremock.version>
{{/if}}
{{#if hasJavaAwaitility}}
		<awaitility.version>4.3.0</awaitility.version>
{{/if}}
{{/if}}
{{#if hasJavaLombok}}
		<lombok.version>1.18.38</lombok.version>
{{/if}}
{{/if}}
	</properties>
{{#unless isJavaSpringBoot}}
{{#if hasJavaTests}}
	<dependencyManagement>
		<dependencies>
			<dependency>
				<groupId>org.junit</groupId>
				<artifactId>junit-bom</artifactId>
				<version>${junit.version}</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>
{{#if hasJavaTestcontainers}}
			<dependency>
				<groupId>org.testcontainers</groupId>
				<artifactId>testcontainers-bom</artifactId>
				<version>${testcontainers.version}</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>
{{/if}}
		</dependencies>
	</dependencyManagement>
{{/if}}
{{/unless}}
	<dependencies>
{{#if isJavaSpringBoot}}
{{#if hasJavaJpa}}
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-data-jpa</artifactId>
		</dependency>
{{/if}}
{{#if hasJavaSecurity}}
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-security</artifactId>
		</dependency>
{{/if}}
{{#if hasJavaActuator}}
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-actuator</artifactId>
		</dependency>
{{/if}}
{{#if hasJavaValidation}}
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-validation</artifactId>
		</dependency>
{{/if}}
{{#if hasJavaFlyway}}
		<dependency>
			<groupId>org.flywaydb</groupId>
			<artifactId>flyway-core</artifactId>
		</dependency>
{{/if}}
{{#if hasJavaLiquibase}}
		<dependency>
			<groupId>org.liquibase</groupId>
			<artifactId>liquibase-core</artifactId>
		</dependency>
{{/if}}
{{#if hasJavaSpringdocOpenapi}}
		<dependency>
			<groupId>org.springdoc</groupId>
			<artifactId>springdoc-openapi-starter-webmvc-ui</artifactId>
			<version>${springdoc.version}</version>
		</dependency>
{{/if}}
{{#if hasJavaLombok}}
		<dependency>
			<groupId>org.projectlombok</groupId>
			<artifactId>lombok</artifactId>
			<version>${lombok.version}</version>
			<optional>true</optional>
		</dependency>
{{/if}}
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-webmvc</artifactId>
		</dependency>
{{#if hasJavaJpa}}
		<dependency>
			<groupId>com.h2database</groupId>
			<artifactId>h2</artifactId>
			<scope>runtime</scope>
		</dependency>
{{/if}}

{{#if hasJavaTests}}
{{#if hasJavaJpa}}
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-data-jpa-test</artifactId>
			<scope>test</scope>
		</dependency>
{{/if}}
{{#if hasJavaSecurity}}
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-security-test</artifactId>
			<scope>test</scope>
		</dependency>
{{/if}}
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-webmvc-test</artifactId>
			<scope>test</scope>
		</dependency>
{{#if hasJavaAssertj}}
		<dependency>
			<groupId>org.assertj</groupId>
			<artifactId>assertj-core</artifactId>
			<version>${assertj.version}</version>
			<scope>test</scope>
		</dependency>
{{/if}}
{{#if hasJavaRestAssured}}
		<dependency>
			<groupId>io.rest-assured</groupId>
			<artifactId>rest-assured</artifactId>
			<version>${rest-assured.version}</version>
			<scope>test</scope>
		</dependency>
{{/if}}
{{#if hasJavaWireMock}}
		<dependency>
			<groupId>org.wiremock</groupId>
			<artifactId>wiremock</artifactId>
			<version>${wiremock.version}</version>
			<scope>test</scope>
		</dependency>
{{/if}}
{{#if hasJavaAwaitility}}
		<dependency>
			<groupId>org.awaitility</groupId>
			<artifactId>awaitility</artifactId>
			<version>${awaitility.version}</version>
			<scope>test</scope>
		</dependency>
{{/if}}
{{#if hasJavaTestcontainers}}
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-testcontainers</artifactId>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>testcontainers-junit-jupiter</artifactId>
			<scope>test</scope>
		</dependency>
{{/if}}
{{/if}}
{{else}}
{{#if hasJavaTests}}
		<dependency>
			<groupId>org.junit.jupiter</groupId>
			<artifactId>junit-jupiter</artifactId>
			<scope>test</scope>
		</dependency>
{{#if hasJavaAssertj}}
		<dependency>
			<groupId>org.assertj</groupId>
			<artifactId>assertj-core</artifactId>
			<version>${assertj.version}</version>
			<scope>test</scope>
		</dependency>
{{/if}}
{{#if hasJavaMockito}}
		<dependency>
			<groupId>org.mockito</groupId>
			<artifactId>mockito-junit-jupiter</artifactId>
			<version>${mockito.version}</version>
			<scope>test</scope>
		</dependency>
{{/if}}
{{#if hasJavaTestcontainers}}
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>junit-jupiter</artifactId>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>testcontainers</artifactId>
			<scope>test</scope>
		</dependency>
{{/if}}
{{#if hasJavaRestAssured}}
		<dependency>
			<groupId>io.rest-assured</groupId>
			<artifactId>rest-assured</artifactId>
			<version>${rest-assured.version}</version>
			<scope>test</scope>
		</dependency>
{{/if}}
{{#if hasJavaWireMock}}
		<dependency>
			<groupId>org.wiremock</groupId>
			<artifactId>wiremock</artifactId>
			<version>${wiremock.version}</version>
			<scope>test</scope>
		</dependency>
{{/if}}
{{#if hasJavaAwaitility}}
		<dependency>
			<groupId>org.awaitility</groupId>
			<artifactId>awaitility</artifactId>
			<version>${awaitility.version}</version>
			<scope>test</scope>
		</dependency>
{{/if}}
{{/if}}
{{/if}}
	</dependencies>

	<build>
		<plugins>
{{#if isJavaSpringBoot}}
			<plugin>
				<groupId>org.springframework.boot</groupId>
				<artifactId>spring-boot-maven-plugin</artifactId>
			</plugin>
{{#if hasJavaLombok}}
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-compiler-plugin</artifactId>
				<version>3.14.0</version>
				<configuration>
					<annotationProcessorPaths>
						<path>
							<groupId>org.projectlombok</groupId>
							<artifactId>lombok</artifactId>
							<version>${lombok.version}</version>
						</path>
					</annotationProcessorPaths>
				</configuration>
			</plugin>
{{/if}}
{{else}}
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-compiler-plugin</artifactId>
				<version>3.14.0</version>
{{#if hasJavaLombok}}
				<configuration>
					<annotationProcessorPaths>
						<path>
							<groupId>org.projectlombok</groupId>
							<artifactId>lombok</artifactId>
							<version>${lombok.version}</version>
						</path>
					</annotationProcessorPaths>
				</configuration>
{{/if}}
			</plugin>
{{#if hasJavaTests}}
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-surefire-plugin</artifactId>
				<version>3.5.2</version>
				<configuration>
					<useModulePath>false</useModulePath>
				</configuration>
			</plugin>
{{/if}}
			<plugin>
				<groupId>org.codehaus.mojo</groupId>
				<artifactId>exec-maven-plugin</artifactId>
				<version>3.5.0</version>
				<configuration>
					<mainClass>{{javaPackageName}}.Application</mainClass>
				</configuration>
			</plugin>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-jar-plugin</artifactId>
				<version>3.4.2</version>
				<configuration>
					<archive>
						<manifest>
							<mainClass>{{javaPackageName}}.Application</mainClass>
						</manifest>
					</archive>
				</configuration>
			</plugin>
{{/if}}
		</plugins>
	</build>
</project>
