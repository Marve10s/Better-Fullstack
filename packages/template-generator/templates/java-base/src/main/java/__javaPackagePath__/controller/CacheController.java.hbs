package {{javaPackageName}}.controller;

import java.time.Instant;
import java.util.Map;

import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RestController;

import {{javaPackageName}}.cache.CachedTimeService;

@RestController
public class CacheController {

  private final CachedTimeService cachedTimeService;

  public CacheController(CachedTimeService cachedTimeService) {
    this.cachedTimeService = cachedTimeService;
  }

  @GetMapping("/cache/time")
  public Map<String, Instant> cachedTime() {
    return Map.of("generatedAt", cachedTimeService.generatedAt());
  }
}
