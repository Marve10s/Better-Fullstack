import java.io.ByteArrayOutputStream;
import java.io.PrintStream;
import java.nio.charset.StandardCharsets;

import org.junit.jupiter.api.Test;

class ApplicationTests {

  @Test
  void mainPrintsGreeting() {
    PrintStream originalOut = System.out;
    ByteArrayOutputStream capturedOutput = new ByteArrayOutputStream();

    try (PrintStream replacement = new PrintStream(capturedOutput, true, StandardCharsets.UTF_8)) {
      System.setOut(replacement);
      Application.main(new String[0]);
    } finally {
      System.setOut(originalOut);
    }

{{#if hasJavaAssertj}}
    assertThat(capturedOutput.toString(StandardCharsets.UTF_8).trim()).isEqualTo("Hello from {{projectName}}");
{{else}}
    assertEquals("Hello from {{projectName}}", capturedOutput.toString(StandardCharsets.UTF_8).trim());
{{/if}}
  }
}
