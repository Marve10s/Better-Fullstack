class ApplicationContainerTests {

  @Container
  static GenericContainer<?> demoContainer = new GenericContainer<>("nginx:1.27-alpine")
    .withExposedPorts(80);

  @Test
  void containerStarts() {
{{#if hasJavaAssertj}}
    assertThat(demoContainer.isRunning()).isTrue();
    assertThat(demoContainer.getFirstMappedPort()).isGreaterThan(0);
{{else}}
    assertTrue(demoContainer.isRunning());
    assertTrue(demoContainer.getFirstMappedPort() > 0);
{{/if}}
  }
}
