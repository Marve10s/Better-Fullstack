defmodule {{elixirModuleName}}.Catalog do
  alias {{elixirModuleName}}.Catalog.Item
{{#if (eq elixirValidation "nimble-options")}}
  alias {{elixirModuleName}}.Catalog.ItemOptions
{{/if}}
{{#if (eq elixirOrm "ecto-sql")}}
  alias {{elixirModuleName}}.Repo
{{/if}}

  def list_items do
{{#if (eq elixirOrm "ecto-sql")}}
    Repo.all(Item)
{{else}}
    [
      %Item{id: 1, name: "Phoenix", description: "Generated by Better Fullstack"}
    ]
{{/if}}
  end

{{#if (eq elixirOrm "ecto-sql")}}
  def get_item!(id), do: Repo.get!(Item, id)
{{else}}
  def get_item!(id) do
    Enum.find(list_items(), &(to_string(&1.id) == to_string(id))) ||
      raise Ecto.NoResultsError, queryable: Item
  end
{{/if}}

  def create_item(attrs) do
{{#if (eq elixirValidation "nimble-options")}}
    with {:ok, attrs} <- ItemOptions.validate(attrs) do
{{#if (eq elixirOrm "ecto-sql")}}
      %Item{}
      |> Item.changeset(attrs)
      |> Repo.insert()
{{else}}
      build_item(attrs)
{{/if}}
    end
{{else}}
{{#if (eq elixirOrm "ecto-sql")}}
    %Item{}
    |> Item.changeset(attrs)
    |> Repo.insert()
{{else}}
    build_item(attrs)
{{/if}}
{{/if}}
  end

{{#if (eq elixirOrm "ecto")}}
  defp build_item(attrs) do
    %Item{}
    |> Item.changeset(attrs)
    |> Ecto.Changeset.apply_action(:insert)
    |> case do
      {:ok, item} -> {:ok, %{item | id: System.unique_integer([:positive])}}
      {:error, changeset} -> {:error, changeset}
    end
  end
{{/if}}
end
