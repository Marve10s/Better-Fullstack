defmodule {{elixirModuleName}}.Catalog do
  alias {{elixirModuleName}}.Catalog.Item
  alias {{elixirModuleName}}.Repo

  def list_items do
    Repo.all(Item)
  end

  def get_item!(id), do: Repo.get!(Item, id)

  def create_item(attrs) do
    %Item{}
    |> Item.changeset(attrs)
    |> Repo.insert()
  end
end
