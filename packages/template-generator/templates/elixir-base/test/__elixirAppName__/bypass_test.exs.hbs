defmodule {{elixirModuleName}}.BypassTest do
  use ExUnit.Case, async: true

  test "fakes an external HTTP service" do
    bypass = Bypass.open()

    Bypass.expect_once(bypass, "GET", "/health", fn conn ->
      Plug.Conn.resp(conn, 200, ~s({"ok":true}))
    end)

    url = "http://localhost:#{bypass.port}/health"

    assert {:ok, response} = Req.get(url)
    assert response.status == 200
    assert response.body == ~s({"ok":true})
  end
end
