{{else if (eq backend "nestjs")}}
/**
 * Wraps an async function to catch and bubble up errors (NestJS natively supports async handlers)
 */
export const asyncHandler = (fn: Function) => {
  return async (...args: unknown[]) => {
    try {
      return await fn(...args);
    } catch (error) {
      throw error;
    }
  };
};
