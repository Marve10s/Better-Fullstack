{{else if (eq backend "nestjs")}}
import { Controller, Get } from "@nestjs/common";
import { ApiResponse } from "../lib/api-response";

/**
 * Health check controller demonstrating backend utilities:
 * - ApiResponse: standardized JSON response with status codes and timestamps
 * - GlobalExceptionFilter: global error handling (wired in your main.ts bootstrap)
 *
 * NestJS natively handles async errors, so asyncHandler is not needed here.
 */
@Controller("health")
export class HealthController {
  @Get()
  async check() {
    const healthData = {
      status: "healthy",
      uptime: process.uptime(),
      timestamp: new Date().toISOString(),
      environment: process.env.NODE_ENV || "development",
      memoryUsage: {
        heapUsed: `${Math.round(process.memoryUsage().heapUsed / 1024 / 1024)}MB`,
        heapTotal: `${Math.round(process.memoryUsage().heapTotal / 1024 / 1024)}MB`,
      },
    };

    return ApiResponse.success(healthData, "Service is healthy");
  }

  @Get("ready")
  async ready() {
    // Simulate a readiness check (e.g. database, cache, external services)
    const checks = {
      database: true,
      cache: true,
    };

    const allReady = Object.values(checks).every(Boolean);

    if (!allReady) {
      return ApiResponse.error("Service is not ready", 503);
    }

    return ApiResponse.success(checks, "All systems ready");
  }
}
