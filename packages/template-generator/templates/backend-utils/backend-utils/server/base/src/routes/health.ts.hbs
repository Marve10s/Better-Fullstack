{{#if (eq backend "hono")}}
import { Hono } from "hono";
import { asyncHandler } from "../lib/async-handler";
import { ApiResponse } from "../lib/api-response";

const health = new Hono();

/**
 * Health check route demonstrating backend utilities:
 * - asyncHandler: wraps async handlers to catch errors automatically
 * - ApiResponse: standardized JSON response with status codes and timestamps
 * - errorHandler: global error middleware (wired in your main server entry)
 */
health.get(
  "/",
  asyncHandler(async (c) => {
    const healthData = {
      status: "healthy",
      uptime: process.uptime(),
      timestamp: new Date().toISOString(),
      environment: process.env.NODE_ENV || "development",
      memoryUsage: {
        heapUsed: `${Math.round(process.memoryUsage().heapUsed / 1024 / 1024)}MB`,
        heapTotal: `${Math.round(process.memoryUsage().heapTotal / 1024 / 1024)}MB`,
      },
    };

    return c.json(ApiResponse.success(healthData, "Service is healthy"));
  })
);

health.get(
  "/ready",
  asyncHandler(async (c) => {
    // Simulate a readiness check (e.g. database, cache, external services)
    const checks = {
      database: true,
      cache: true,
    };

    const allReady = Object.values(checks).every(Boolean);

    if (!allReady) {
      return c.json(ApiResponse.error("Service is not ready", 503), 503);
    }

    return c.json(ApiResponse.success(checks, "All systems ready"));
  })
);

export default health;
