{{#if (eq rustErrorHandling "anyhow-thiserror")}}
use thiserror::Error;

/// Application-level errors using thiserror for custom types.
/// Use `anyhow::Result` in application code for ad-hoc errors,
/// and `AppError` for well-defined domain errors.
#[derive(Debug, Error)]
#[allow(dead_code)]
pub enum AppError {
    #[error("Configuration error: {0}")]
    Config(String),

    #[error("Database error: {0}")]
    Database(String),

    #[error("Not found: {0}")]
    NotFound(String),

    #[error("Internal error: {0}")]
    Internal(#[from] anyhow::Error),
}
{{else if (eq rustErrorHandling "eyre")}}
// Application-level errors use eyre for rich error reports.
// Use `eyre::Result` throughout your application and
// `color_eyre::eyre::eyre!` / `color_eyre::eyre::bail!` macros.
//
// color-eyre is installed in main() to provide pretty backtraces.
{{/if}}
