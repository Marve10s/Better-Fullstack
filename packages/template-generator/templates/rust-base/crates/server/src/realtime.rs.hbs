//! WebSocket echo server built on tokio-tungstenite.
//!
//! Run it alongside the HTTP server, e.g. from `main`:
//!
//! ```ignore
//! tokio::spawn(realtime::serve("0.0.0.0:8765"));
//! ```

#![allow(dead_code)]

use futures_util::{SinkExt, StreamExt};
use tokio::net::{TcpListener, TcpStream};
use tokio_tungstenite::accept_async;

/// Accept WebSocket connections forever, echoing every message.
pub async fn serve(addr: &str) -> Result<(), Box<dyn std::error::Error + Send + Sync>> {
    let listener = TcpListener::bind(addr).await?;
    loop {
        let (stream, _) = listener.accept().await?;
        tokio::spawn(handle_connection(stream));
    }
}

async fn handle_connection(stream: TcpStream) {
    let Ok(ws_stream) = accept_async(stream).await else {
        return;
    };
    let (mut write, mut read) = ws_stream.split();
    while let Some(Ok(message)) = read.next().await {
        if (message.is_text() || message.is_binary()) && write.send(message).await.is_err() {
            break;
        }
    }
}
{{/if}}
