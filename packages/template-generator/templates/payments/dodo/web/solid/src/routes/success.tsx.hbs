import { createFileRoute } from "@tanstack/solid-router";
import { Show } from "solid-js";

export const Route = createFileRoute("/success")({
  component: SuccessPage,
  validateSearch: (search) => ({
    payment_id: search.payment_id as string | undefined,
    subscription_id: search.subscription_id as string | undefined,
  }),
});

function SuccessPage() {
  const searchParams = Route.useSearch();
  const paymentId = searchParams().payment_id;
  const subscriptionId = searchParams().subscription_id;

  return (
    <div class="container mx-auto px-4 py-8">
      <h1 class="text-2xl font-bold mb-4">Payment Successful!</h1>
      <p class="text-gray-600 mb-4">
        Thank you for your purchase. Your Dodo Payments checkout has completed successfully.
      </p>
      <Show when={paymentId}>
        <p class="text-sm text-gray-500">Payment ID: {paymentId}</p>
      </Show>
      <Show when={subscriptionId}>
        <p class="text-sm text-gray-500">Subscription ID: {subscriptionId}</p>
      </Show>
    </div>
  );
}
