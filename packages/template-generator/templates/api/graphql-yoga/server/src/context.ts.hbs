{{#if (isBetterAuth auth)}}
import type { Session, User } from "better-auth";
{{/if}}
import type { PothosContext } from "./graphql/builder{{#if (eq backend "adonisjs")}}.js{{/if}}";

{{#if (isBetterAuth auth)}}
export function createContext(session: { user: User; session: Session } | null): PothosContext {
  return { session };
}
{{else}}
export function createContext(): PothosContext {
  return {};
}
{{/if}}
