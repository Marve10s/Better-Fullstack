{{#if (eq backend "hono")}}
import type { Context as HonoContext } from "hono";
{{#if (isBetterAuth auth)}}
import type { Session, User } from "better-auth";
{{/if}}

export type Context = {
  honoContext: HonoContext;
{{#if (isBetterAuth auth)}}
  session: { user: User; session: Session } | null;
{{/if}}
};

export function createContext(c: HonoContext{{#if (isBetterAuth auth)}}, session: { user: User; session: Session } | null{{/if}}): Context {
  return {
    honoContext: c,
{{#if (isBetterAuth auth)}}
    session,
{{/if}}
  };
}
