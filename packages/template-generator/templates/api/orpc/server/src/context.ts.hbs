{{else if (eq backend 'express')}}
import type { Request } from "express";
{{#if (isBetterAuth auth)}}
import { auth } from "@{{projectName}}/auth";
{{/if}}

interface CreateContextOptions {
	req: Request;
}

{{#if (isBetterAuth auth)}}
function nodeHeadersToHeaders(headers: Request["headers"]) {
	const webHeaders = new Headers();
	for (const [key, value] of Object.entries(headers)) {
		if (Array.isArray(value)) {
			for (const item of value) webHeaders.append(key, item);
		} else if (typeof value === "string") {
			webHeaders.set(key, value);
		}
	}
	return webHeaders;
}

export async function createContext(opts: CreateContextOptions) {
	const session = await auth.api.getSession({
		headers: nodeHeadersToHeaders(opts.req.headers),
	});
	return {
		session,
	};
{{else}}
export async function createContext(_opts: CreateContextOptions) {
  // No auth configured
	return {
		session: null,
	};
{{/if}}
}

