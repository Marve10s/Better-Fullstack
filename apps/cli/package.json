{
  "name": "create-better-fullstack",
  "version": "1.4.7",
  "description": "Scaffold production-ready fullstack apps in seconds. Pick your stack from 270+ options — the CLI wires everything together.",
  "keywords": [
    "angular",
    "astro",
    "authentication",
    "better-auth",
    "better-fullstack",
    "biome",
    "boilerplate",
    "bun",
    "cli",
    "create",
    "create-app",
    "desktop",
    "developer-tools",
    "docker",
    "drizzle",
    "elysia",
    "expo",
    "fastapi",
    "fullstack",
    "go",
    "golang",
    "hono",
    "mobile",
    "monorepo",
    "nextjs",
    "nuxt",
    "payments",
    "pnpm",
    "prisma",
    "project-generator",
    "pwa",
    "python",
    "react",
    "react-native",
    "rust",
    "scaffold",
    "scaffolding",
    "shadcn",
    "solid",
    "starter",
    "starter-kit",
    "svelte",
    "sveltekit",
    "tailwind",
    "tanstack",
    "tauri",
    "template",
    "trpc",
    "turborepo",
    "type-safety",
    "typescript",
    "vite",
    "vue",
    "web-app",
    "yarn"
  ],
  "homepage": "https://better-fullstack.dev/",
  "license": "MIT",
  "author": "Marve10s",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Marve10s/Better-Fullstack.git",
    "directory": "apps/cli"
  },
  "bin": {
    "create-better-fullstack": "dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./cli": {
      "import": "./dist/cli.mjs"
    },
    "./virtual": {
      "types": "./dist/virtual.d.mts",
      "import": "./dist/virtual.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --publint",
    "dev": "tsdown --watch",
    "lint": "oxlint . && tsc --noEmit && bun test test/cli-builder-sync.test.ts",
    "check-types": "tsc --noEmit",
    "test": "bun test ./test/*.test.ts",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:ci": "CI=1 bun test --bail=5",
    "test:e2e": "E2E=1 bun test test/e2e/e2e.e2e.ts",
    "test:astro-combos": "bun run scripts/test-astro-combinations.ts",
    "test:matrix": "MATRIX_MODE=batched bun test ./test/matrix/matrix-test.test.ts",
    "test:matrix:fast": "MATRIX_MODE=sample MATRIX_SAMPLE=0.1 bun test ./test/matrix/matrix-test.test.ts",
    "test:matrix:full": "MATRIX_MODE=full bun test ./test/matrix/matrix-test.test.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@better-fullstack/template-generator": "workspace:*",
    "@better-fullstack/types": "workspace:*",
    "@clack/core": "^0.5.0",
    "@clack/prompts": "^1.1.0",
    "@orpc/server": "^1.13.7",
    "consola": "^3.4.2",
    "env-paths": "^4.0.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.4",
    "gradient-string": "^3.0.0",
    "handlebars": "^4.7.8",
    "jsonc-parser": "^3.3.1",
    "oxfmt": "^0.19.0",
    "picocolors": "^1.1.1",
    "tinyglobby": "^0.2.15",
    "trpc-cli": "^0.12.1",
    "ts-morph": "^27.0.2",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "publint": "^0.3.18",
    "tsdown": "^0.18.2",
    "typescript": "^5.9.3"
  }
}
