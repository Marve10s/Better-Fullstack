---
const { entry } = Astro.locals.starlightRoute;
const title = entry.data.title;
const sourcePath = `apps/docs/src/content/docs/${entry.id}`;
const sourceUrl = `https://github.com/Marve10s/Better-Fullstack/blob/main/${sourcePath}`;
const rawUrl = `https://raw.githubusercontent.com/Marve10s/Better-Fullstack/main/${sourcePath}`;
---

<div class="docs-page-heading">
  <div>
    <h1 id="_top">{title}</h1>
  </div>
  <div class="docs-page-actions" aria-label="Page actions">
    <button class="docs-action docs-copy-md-button" type="button" data-copy-label="Copy MD">
      <svg class="docs-copy-md-icon-copy" aria-hidden="true" viewBox="0 0 16 16">
        <rect x="5" y="5" width="9" height="9" rx="1.25" />
        <path d="M3 11V3.75A.75.75 0 0 1 3.75 3H11" />
      </svg>
      <svg class="docs-copy-md-icon-check" aria-hidden="true" viewBox="0 0 16 16">
        <polyline points="3.25 8.75 6.5 11.75 12.75 4.75" />
      </svg>
      <span class="docs-copy-md-label">Copy MD</span>
    </button>
    <details class="docs-open-menu">
      <summary class="docs-action">
        <span>Open in</span>
        <svg aria-hidden="true" viewBox="0 0 16 16">
          <path d="m4.5 6 3.5 3.5L11.5 6" />
        </svg>
      </summary>
      <div class="docs-open-menu-panel">
        <a href={sourceUrl} target="_blank" rel="noreferrer">GitHub</a>
        <a href={rawUrl} target="_blank" rel="noreferrer">Raw MD</a>
        <a href="/docs/llms.txt" target="_blank" rel="noreferrer">llms.txt</a>
      </div>
    </details>
  </div>
</div>

<script>
  function textContent(node: Node) {
    return (node.textContent || "").replace(/\s+/g, " ").trim();
  }

  function tableToMarkdown(table: HTMLTableElement): string {
    const rows = Array.from(table.querySelectorAll("tr")).map((row: HTMLTableRowElement) =>
      Array.from(row.children).map((cell: Element) => textContent(cell).replace(/\|/g, "\\|")),
    );
    if (rows.length === 0) return "";
    const columnCount = Math.max(...rows.map((row) => row.length));
    const normalize = (row: string[]) =>
      Array.from({ length: columnCount }, (_, index) => row[index] || "");
    const [head, ...body] = rows.map(normalize);
    return [
      `| ${head.join(" | ")} |`,
      `| ${head.map(() => "---").join(" | ")} |`,
      ...body.map((row) => `| ${row.join(" | ")} |`),
    ].join("\n");
  }

  function nodeToMarkdown(node: Element): string {
    if (!(node instanceof HTMLElement)) return "";
    const tag = node.tagName.toLowerCase();

    if (/^h[2-6]$/.test(tag)) return `${"#".repeat(Number(tag[1]))} ${textContent(node)}`;
    if (tag === "p") return textContent(node);
    if (tag === "pre") return `\`\`\`\n${node.textContent?.trimEnd() || ""}\n\`\`\``;
    if (tag === "ul" || tag === "ol") {
      return Array.from(node.children)
        .map((item, index) => `${tag === "ol" ? `${index + 1}.` : "-"} ${textContent(item)}`)
        .join("\n");
    }
    if (tag === "blockquote") return textContent(node).split("\n").map((line) => `> ${line}`).join("\n");
    if (tag === "table") return tableToMarkdown(node as HTMLTableElement);
    if (tag === "hr") return "---";

    return Array.from(node.children).map((child) => nodeToMarkdown(child)).filter(Boolean).join("\n\n");
  }

  function pageToMarkdown(): string {
    const title = document.querySelector("h1")?.textContent?.trim();
    const content = document.querySelector(".sl-markdown-content");
    const sections = title ? [`# ${title}`] : [];
    if (content) {
      sections.push(
        Array.from(content.children)
          .map((node) => nodeToMarkdown(node))
          .filter(Boolean)
          .join("\n\n"),
      );
    }
    return sections.filter(Boolean).join("\n\n").trim();
  }

  for (const button of document.querySelectorAll<HTMLButtonElement>(".docs-copy-md-button")) {
    let resetTimer: number | undefined;
    button.addEventListener("click", async () => {
      const label = button.querySelector<HTMLSpanElement>(".docs-copy-md-label");
      const defaultLabel = button.getAttribute("data-copy-label") || "Copy MD";
      let state: "copied" | "error";
      try {
        await navigator.clipboard.writeText(pageToMarkdown());
        state = "copied";
        if (label) label.textContent = "Copied";
      } catch {
        state = "error";
        if (label) label.textContent = "Copy failed";
      }
      button.dataset.copied = state;
      if (resetTimer) window.clearTimeout(resetTimer);
      resetTimer = window.setTimeout(() => {
        delete button.dataset.copied;
        if (label) label.textContent = defaultLabel;
      }, 1600);
    });
  }
</script>
