---
const links = [
  { href: "/new?view=command&file=", label: "Builder" },
  { href: "/new?view=presets&file=", label: "Presets" },
  { href: "/mcp", label: "MCP" },
  { href: "/docs/", label: "Docs", active: true },
];
---

<div class="docs-main-header">
  <div class="docs-header-primary">
    <a href="/" class="docs-brand" aria-label="Better Fullstack home">
      <span class="docs-brand-short">b<span>-f</span></span>
      <span class="docs-brand-full">better<span>fullstack</span></span>
    </a>

    <nav class="docs-header-links" aria-label="Primary navigation">
      {links.map((link) => (
        <a href={link.href} aria-current={link.active ? "page" : undefined}>{link.label}</a>
      ))}
    </nav>
  </div>

  <div class="docs-header-actions">
    <button class="docs-search-trigger" type="button" aria-label="Search docs" data-docs-search-trigger>
      <svg aria-hidden="true" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="8" />
        <path d="m21 21-4.3-4.3" />
      </svg>
      <span class="docs-search-trigger-label">Search…</span>
      <kbd class="docs-search-kbd">
        <span class="docs-search-kbd-cmd">&#8984;</span>
        <span>K</span>
      </kbd>
    </button>

    <a class="docs-icon-link" href="https://github.com/Marve10s/Better-Fullstack" aria-label="GitHub" target="_blank" rel="noreferrer">
      <svg aria-hidden="true" viewBox="0 0 16 16">
        <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2 .37-2.53-.49-2.7-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z" />
      </svg>
    </a>

    <button class="docs-theme-toggle" type="button" aria-label="Toggle theme">
      <svg class="docs-theme-sun" aria-hidden="true" viewBox="0 0 24 24">
        <circle cx="12" cy="12" r="4" />
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
      </svg>
      <svg class="docs-theme-moon" aria-hidden="true" viewBox="0 0 24 24">
        <path d="M20.5 14.5A8.5 8.5 0 0 1 9.5 3.5a7 7 0 1 0 11 11Z" />
      </svg>
    </button>
  </div>
</div>

<script>
  type Theme = "dark" | "light";

  const storageKey = "starlight-theme";
  const getCurrentTheme = (): Theme =>
    document.documentElement.dataset.theme === "light" ? "light" : "dark";

  function setTheme(theme: Theme): void {
    document.documentElement.dataset.theme = theme;
    localStorage.setItem(storageKey, theme);
    document.querySelectorAll<HTMLButtonElement>(".docs-theme-toggle").forEach((button) => {
      button.setAttribute("aria-label", `Switch to ${theme === "dark" ? "light" : "dark"} mode`);
    });
  }

  setTheme(getCurrentTheme());

  document.querySelectorAll<HTMLButtonElement>(".docs-theme-toggle").forEach((button) => {
    button.addEventListener("click", () => {
      setTheme(getCurrentTheme() === "dark" ? "light" : "dark");
    });
  });

  // Route the custom search trigger into Starlight's built-in Pagefind dialog.
  // Starlight listens for Cmd/Ctrl+K globally; simulating a click on its hidden
  // trigger is the supported integration surface. As a fallback we dispatch a
  // keyboard event at the document level.
  document.querySelectorAll<HTMLButtonElement>("[data-docs-search-trigger]").forEach((button) => {
    button.addEventListener("click", () => {
      const starlightTrigger = document.querySelector<HTMLButtonElement>(
        'button[data-open-modal], site-search button[aria-label="Search"]',
      );
      if (starlightTrigger) {
        starlightTrigger.click();
        return;
      }
      document.dispatchEvent(
        new KeyboardEvent("keydown", {
          key: "k",
          code: "KeyK",
          ctrlKey: true,
          metaKey: true,
          bubbles: true,
        }),
      );
    });
  });
</script>
